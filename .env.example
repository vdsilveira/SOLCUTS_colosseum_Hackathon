# ============================================================
# SolCuts - Variáveis de Ambiente Centralizadas (Docker Compose)
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# O docker-compose.yaml lê deste .env na raiz do projeto.
# ============================================================

# --- Chave Compartilhada (Oracle <-> Backend-views) ----------
# Gerada automaticamente pelo setup.sh ou manualmente via:
#   openssl rand -hex 16
APP_API_KEY=CHANGE_ME

# --- YouTube API (Backend-views-Solana) ----------------------
YOUTUBE_API_KEY=CHANGE_ME

# --- Solana ---------------------------------------------------
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=J45dp2TMQXx5v5RDygsF3im7URJqu7QQ996V1kqXeNxN

# --- Oracle Keypair -------------------------------------------
# Gere com:  python3 AI_agente-Oracle_colosseum_Hackathon/scripts/generate_oracle_keypair.py
ORACLE_PUBLIC_KEY=CHANGE_ME
ORACLE_PRIVATE_KEY=CHANGE_ME

# --- Thresholds de Validação ----------------------------------
TRANSCRIPT_MIN_SCORE=0.70
FRAME_SIMILARITY_THRESHOLD=0.70
FRAME_MIN_MATCHES=3
FRAME_TOTAL_SAMPLES=5

# --- Polling (segundos) ---------------------------------------
POLL_INTERVAL_SECONDS=300

# --- Core API -------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./solcuts.db
CORS_ORIGINS=["http://localhost:3000"]

# --- Database Oracle (SQLite local no container) ---------------
ORACLE_DATABASE_URL=sqlite:///oracle.db

# --- Alerts (opcional) ----------------------------------------
ALERT_WEBHOOK_URL=

# --- Solana Program Seeds (testes locais) ----------------------
COLOSSEUM_ORACLE_SEED=sua-seed-secreta-oracle
COLOSSEUM_CREATOR_SEED=sua-seed-secreta-creator
COLOSSEUM_EDITOR_SEED=sua-seed-secreta-editor
COLOSSEUM_EDITOR2_SEED=sua-seed-secreta-editor2
COLOSSEUM_EDITOR3_SEED=sua-seed-secreta-editor3
COLOSSEUM_POOR_USER_SEED=sua-seed-secreta-pooruser
